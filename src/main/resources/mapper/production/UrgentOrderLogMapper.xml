<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fine.Dao.production.UrgentOrderLogMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.fine.model.production.UrgentOrderLog">
        <id column="id" property="id"/>
        <result column="insert_no" property="insertNo"/>
        <result column="schedule_id" property="scheduleId"/>
        <result column="schedule_no" property="scheduleNo"/>
        <result column="order_id" property="orderId"/>
        <result column="order_no" property="orderNo"/>
        <result column="order_item_id" property="orderItemId"/>
        <result column="customer" property="customer"/>
        <result column="customer_level" property="customerLevel"/>
        <result column="insert_reason" property="insertReason"/>
        <result column="priority_before" property="priorityBefore"/>
        <result column="priority_after" property="priorityAfter"/>
        <result column="required_date" property="requiredDate"/>
        <result column="apply_by" property="applyBy"/>
        <result column="apply_time" property="applyTime"/>
        <result column="approve_by" property="approveBy"/>
        <result column="approve_time" property="approveTime"/>
        <result column="approve_result" property="approveResult"/>
        <result column="approve_remark" property="approveRemark"/>
        <result column="affected_schedules" property="affectedSchedules"/>
        <result column="affected_orders" property="affectedOrders"/>
        <result column="delay_days" property="delayDays"/>
        <result column="status" property="status"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 基础字段 -->
    <sql id="Base_Column_List">
        id, insert_no, schedule_id, schedule_no, order_id, order_no, order_item_id,
        customer, customer_level, insert_reason, priority_before, priority_after,
        required_date, apply_by, apply_time, approve_by, approve_time,
        approve_result, approve_remark, affected_schedules, affected_orders,
        delay_days, status, remark, create_time, update_time
    </sql>

    <!-- 分页查询紧急插单记录 -->
    <select id="selectUrgentOrderList" parameterType="map" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM urgent_insert_order
        <where>
            <if test="insertNo != null and insertNo != ''">
                AND insert_no LIKE CONCAT('%', #{insertNo}, '%')
            </if>
            <if test="orderNo != null and orderNo != ''">
                AND order_no LIKE CONCAT('%', #{orderNo}, '%')
            </if>
            <if test="customer != null and customer != ''">
                AND customer LIKE CONCAT('%', #{customer}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="startTime != null">
                AND apply_time >= #{startTime}
            </if>
            <if test="endTime != null">
                AND apply_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 根据排程ID查询 -->
    <select id="selectByScheduleId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM urgent_insert_order
        WHERE schedule_id = #{scheduleId}
        ORDER BY create_time DESC
    </select>

</mapper>
